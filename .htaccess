# === Лимиты для больших запросов ===
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300
php_value memory_limit 256M

# === Безопасность: Заголовки HTTP ===
<IfModule mod_headers.c>
    # Принудительный HTTPS (включить после настройки SSL)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Защита от clickjacking
    Header always set X-Frame-Options "DENY"
    
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Запрет определения MIME типа
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (базовая защита)
    Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' https: data:;"
</IfModule>

# === Редирект на HTTPS (раскомментировать после настройки SSL) ===
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteCond %{HTTP_HOST} !^localhost [NC]
#     RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# === Защита конфиденциальных файлов ===
# Блокировка доступа к файлам конфигурации и логам
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "^\.optimization_applied">
    Require all denied
</FilesMatch>
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(log|bak|backup|tmp)$">
    Require all denied
</FilesMatch>

# Блокировка доступа к папкам
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Запрет доступа к скрытым файлам/папкам (начинаются с точки)
    RewriteRule ^\.(?!well-known/) - [F]
</IfModule>

# === Кэширование статических ресурсов ===
<IfModule mod_expires.c>
    ExpiresActive On
    
    # CSS и JavaScript - минифицированные версии кэшируем дольше
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Собранные файлы (build) кэшируем еще дольше
    <FilesMatch "\.(min\.css|min\.js)$">
        ExpiresDefault "access plus 1 year"
    </FilesMatch>
    
    # Изображения
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # Шрифты
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    
    # HTML и JSON не кэшируем
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# === Сжатие для ускорения загрузки ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript text/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/x-font-ttf application/x-font-opentype
    AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# === ETag для условных запросов ===
<IfModule mod_headers.c>
    # Включаем ETag для статических файлов
    FileETag MTime Size
    
    # Кэширование для собранных файлов
    <FilesMatch "\.(min\.css|min\.js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Кэширование для обычных CSS/JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# === Отключение вывода версии PHP ===
<IfModule mod_php.c>
    php_flag expose_php Off
</IfModule>

# === Защита от директорного листинга ===
Options -Indexes

# === Файл индекса по умолчанию ===
DirectoryIndex login.php index.php
